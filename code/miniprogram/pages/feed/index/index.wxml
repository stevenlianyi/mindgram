<view class="page">
  <view class="nav-row">
    <view>
      <view class="page-title">好友动态</view>
      <view class="page-subtitle">朋友们今天留下的 Emoji 谜语</view>
    </view>
    <button class="icon-btn">🔍</button>
  </view>

  <view class="section" wx:if="{{moodList.length}}">
    <mood-card
      wx:for="{{moodList}}"
      wx:key="postID"
      item="{{item}}"
      bind:guess="handleGuess"
    />
  </view>

  <view class="section empty" wx:else>
    <view class="empty-emoji">💭</view>
    <view>还没有好友动态</view>
    <view class="feed-empty-action">
      <button class="btn btn--ghost" bindtap="goPost">先发布一条</button>
    </view>
  </view>
</view>
