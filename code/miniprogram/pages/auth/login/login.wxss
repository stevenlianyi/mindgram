.login-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 96rpx 48rpx 72rpx;
  background: linear-gradient(180deg, #F8F9FA 0%, #E8F4FD 60%, #D4F0F0 100%);
}

.login-brand {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
  font-size: 72rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.login-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.login-subtitle {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #6B7280;
}

.login-orbits {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  margin: 72rpx 0 88rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.28);
  border-radius: 50%;
}

.login-orbits::before {
  position: absolute;
  inset: 72rpx;
  content: "";
  border: 2rpx dashed rgba(162, 155, 254, 0.32);
  border-radius: 50%;
}

.orbit-emoji {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  font-size: 44rpx;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.orbit-emoji--joy {
  top: -24rpx;
  left: 136rpx;
}

.orbit-emoji--calm {
  right: 0;
  bottom: 64rpx;
}

.orbit-emoji--sad {
  left: 8rpx;
  bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  background: #07C160;
  border-radius: 999rpx;
}

.login-agreement {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
}

.login-agreement text {
  color: #4ECDC4;
}
