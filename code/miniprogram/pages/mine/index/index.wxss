.mine-profile {
  display: flex;
  align-items: center;
  padding: 32rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #4ECDC4, #A29BFE);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.mine-profile__avatar {
  width: 112rpx;
  height: 112rpx;
  background: rgba(255, 255, 255, 0.24);
}

.mine-profile__main {
  min-width: 0;
  margin-left: 22rpx;
}

.mine-profile__name {
  overflow: hidden;
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine-profile__meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.mine-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.mine-stat {
  padding: 24rpx 12rpx;
  text-align: center;
  background: #FFFFFF;
  border: 1rpx solid #F3F4F6;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mine-stat__value {
  font-size: 38rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.mine-stat__label {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.badge-card {
  min-height: 128rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.badge-emoji {
  font-size: 52rpx;
}

.badge-name {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6B7280;
}
